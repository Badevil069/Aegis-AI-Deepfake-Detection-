# Google Cloud API Credentials
# Use your own JSON files here.
# Do not commit real credentials.
# For Cloud Run, prefer Secret Manager and mount the JSON as a file.
GOOGLE_APPLICATION_CREDENTIALS=D:\path\to\your\service-account.json

# Document verification credentials (your account)
# Used by engines/auditor.py
EYES_KEY_PATH=D:\path\to\your\service-account.json

# Vertex AI credentials (optional reviewer for document scans)
# Used by engines/analyzer.py
# If your same JSON has Vertex role, set BRAIN_KEY_PATH to that same file.
# Cloud Run tip: set BRAIN_KEY_PATH to the mounted secret path (e.g., /var/secrets/vertex-ai-key).
BRAIN_KEY_PATH=D:\path\to\your\service-account.json

# Vertex AI Settings
# These identify the GCP project and region for Vertex AI.
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=
# Optional explicit model override; defaults to gemini-1.5-flash-002 in code fallback chain.
VERTEX_MODEL_NAME=

# Vertex document reviewer policy in server.py
# suspicious_only (default): run Vertex only on suspicious Cloud Vision/local audit results
# fallback: run Vertex only if auditor is unavailable
# always: run Vertex for every upload (higher cost)
# off: disable Vertex document reviewer
VERTEX_DOCUMENT_REVIEW_POLICY=suspicious_only

# Backend Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# WebRTC TURN Server (optional — for production cross-network calls)
# TURN_SERVER_URL=turn:your-turn-server.com:3478
# TURN_USERNAME=
# TURN_PASSWORD=

# Other API Keys
# e.g., CUSTOM_API_KEY=your_secret_key_here
